@{
    Layout = "_Layout";
}
@model List<StoreApp.Models.Product>
@section Footer {
    <div>
        Only for Index footer
    </div>
}

@foreach (StoreApp.Models.Product product in Model)
{
    <div>
        <h3>@product.ProductName</h3>
        <p>@product.Price</p>
        <a href="/Product/Get/@product.ProductId">Get Details</a>
    </div>
}